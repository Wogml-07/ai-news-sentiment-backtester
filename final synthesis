# ========== 네이버 뉴스 API 크롤링 함수 정의 ==========
# search_keyword: 검색할 키워드 (예: '삼성전자')
# client_id: 네이버 개발자 센터에서 발급받은 클라이언트 ID
# client_secret: 네이버 개발자 센터에서 발급받은 클라이언트 Secret
def crawl_naver_news_api(search_keyword, client_id, client_secret):
    # 네이버 뉴스 검색 API 엔드포인트 URL
    url = "https://openapi.naver.com/v1/search/news.json"

    # API 호출에 필요한 헤더 설정 (인증 정보 포함)
    headers = {
        "X-Naver-Client-Id": 'D4XLqgn7NBXGWwY0bVCD', # 발급받은 Client ID
        "X-Naver-Client-Secret": '1hboir3qG_' # 발급받은 Client Secret
    }

    # API 요청 파라미터 설정
    params = {
        "query": search_keyword, # 검색할 키워드
        "display": 10, # 한 번에 가져올 검색 결과 수 (최대 100)
        "sort": "date" # 검색 결과 정렬 방식 (date: 날짜순, sim: 정확도순)
    }

    try:
        print(f"🔍 네이버 API로 '{search_keyword}' 뉴스 검색 중...")
        # requests 라이브러리를 사용하여 GET 요청 보내기
        response = requests.get(url, headers=headers, params=params)
        # HTTP 요청이 성공했는지 확인 (200 OK가 아니면 예외 발생)
        response.raise_for_status()

        # 응답 받은 JSON 데이터를 파이썬 딕셔너리로 변환
        data = response.json()
        # 'items' 키에서 뉴스 목록을 가져옴 (없으면 빈 리스트)
        items = data.get('items', [])

        # 검색 결과가 없을 경우 메시지 출력 및 빈 리스트 반환
        if not items:
            print("⚠️ 검색 결과가 없습니다.")
            return []

        news_list = [] # 수집된 뉴스를 저장할 리스트
        for idx, item in enumerate(items):
            # 뉴스 제목에서 HTML 태그와 특수 문자 제거
            title = item['title'].replace('<b>', '').replace('</b>', '').replace('&quot;', '"')
            link = item['link'] # 뉴스 링크
            pub_date_str = item['pubDate'] # 발행일 문자열

            try:
                # 발행일 문자열을 datetime 객체로 변환
                pub_date = datetime.strptime(pub_date_str, "%a, %d %b %Y %H:%M:%S %z")
            except:
                # 날짜 변환 실패 시 현재 시간으로부터 차등적으로 시간 설정 (오류 방지)
                pub_date = datetime.now() - timedelta(hours=idx * 2)

            # 뉴스 정보를 딕셔너리 형태로 리스트에 추가
            news_list.append({
                "title": title,
                "link": link,
                "pub_date": pub_date.strftime("%Y-%m-%d %H:%M:%S") # YYYY-MM-DD HH:MM:SS 형식으로 저장
            })

            print(f"  [{idx+1}] {title[:60]}...") # 수집 진행 상황 출력

        print(f"\n✅ 총 {len(news_list)}개의 뉴스 수집 완료!") # 최종 수집 결과 출력
        return news_list # 수집된 뉴스 리스트 반환

    # HTTP 오류 발생 시 처리
    except requests.exceptions.HTTPError as e:
        if response.status_code == 401:
            print("❌ API 인증 실패! Client ID와 Secret을 확인하세요.") # 인증 오류
        elif response.status_code == 429:
            print("⚠️ API 호출 한도 초과. 잠시 후 다시 시도하세요.") # 호출 한도 초과
        else:
            print(f"❌ API 오류: {e}") # 그 외 HTTP 오류
        return [] # 빈 리스트 반환
    # 기타 예외 발생 시 처리
    except Exception as e:
        print(f"❌ 오류 발생: {e}") # 일반 오류
        return [] # 빈 리스트 반환

# ========== AI 감성 분석 클래스 정의 ==========
class FinancialSentimentScorer:
    # 클래스 초기화 메서드
    # model_name: 사용할 사전 학습된 감성 분석 모델의 이름
    def __init__(self, model_name="snunlp/KR-FinBERT-SC"):
        print(f"\n🤖 [AI 모델 로딩] {model_name}")
        # 토크나이저 로드 (텍스트를 모델 입력 형식으로 변환)
        self.tokenizer = AutoTokenizer.from_pretrained(model_name)
        # 시퀀스 분류를 위한 모델 로드
        self.model = AutoModelForSequenceClassification.from_pretrained(model_name)
        # GPU 사용 가능 여부 확인 및 디바이스 설정
        self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
        self.model.to(self.device) # 모델을 지정된 디바이스로 이동
        self.model.eval() # 모델을 평가 모드로 설정 (드롭아웃 등 비활성화)
        print(f"✅ 모델 준비 완료 (디바이스: {self.device})\n")

    # 단일 텍스트에 대한 감성 점수 계산 메서드
    # text: 감성 분석할 텍스트
    def compute_sentiment_score(self, text: str) -> dict:
        # 텍스트가 비어 있거나 공백만 있는 경우 기본 중립 값 반환
        if not text or not text.strip():
            return {"sentiment_score": 0.0, "dominant_label": "중립",
                    "prob_positive": 0.0, "prob_negative": 0.0, "prob_neutral": 1.0}

        # 텍스트를 토큰화하고 모델 입력 형식으로 변환
        inputs = self.tokenizer(text, return_tensors="pt", truncation=True,
                               max_length=512, padding=True).to(self.device)

        # 그래디언트 계산 비활성화 (추론 시 메모리 절약 및 속도 향상)
        with torch.no_grad():
            # 모델에 입력하여 예측값 얻기
            outputs = self.model(**inputs)
            # 로짓(logit) 값을 확률로 변환 (소프트맥스 함수 사용)
            probabilities = F.softmax(outputs.logits, dim=-1).squeeze().cpu().numpy()

        # 각 감성(부정, 중립, 긍정)에 대한 확률 추출
        prob_neg = float(probabilities[0]) # 부정 확률
        prob_neu = float(probabilities[1]) # 중립 확률
        prob_pos = float(probabilities[2]) # 긍정 확률

        # 감성 점수 계산 (긍정 확률 - 부정 확률)
        sentiment_score = prob_pos - prob_neg
        labels = ["부정", "중립", "긍정"] # 감성 레이블
        # 가장 높은 확률을 가진 감성 레이블 선택
        final_label = labels[np.argmax(probabilities)]

        # 감성 분석 결과 딕셔너리로 반환
        return {
            "sentiment_score": round(sentiment_score, 4), # 감성 점수 (소수점 4째 자리까지)
            "dominant_label": final_label, # 지배적인 감성 레이블
            "prob_positive": round(prob_pos, 4), # 긍정 확률
            "prob_negative": round(prob_neg, 4), # 부정 확률
            "prob_neutral": round(prob_neu, 4) # 중립 확률
        }

    # 데이터프레임의 특정 텍스트 컬럼에 대해 감성 분석을 수행하는 메서드
    # df: 분석할 데이터프레임
    # text_column: 감성 분석을 수행할 텍스트가 담긴 컬럼 이름
    def pipeline_scoring(self, df: pd.DataFrame, text_column: str) -> pd.DataFrame:
        scores, labels, pos_probs, neg_probs, neu_probs = [], [], [], [], [] # 결과를 저장할 리스트 초기화

        total = len(df) # 전체 뉴스 개수
        for idx, row in df.iterrows(): # 데이터프레임의 각 행에 대해 반복
            res = self.compute_sentiment_score(str(row[text_column])) # 해당 텍스트에 대한 감성 점수 계산
            scores.append(res["sentiment_score"])
            labels.append(res["dominant_label"])
            pos_probs.append(res["prob_positive"])
            neg_probs.append(res["prob_negative"])
            neu_probs.append(res["prob_neutral"])

            # 감성 레이블에 따른 이모티콘 설정
            emotion_icon = "😊" if res['dominant_label'] == "긍정" else "😢" if res['dominant_label'] == "부정" else "😐"
            # 진행 상황 출력
            print(f"  [{idx+1}/{total}] {emotion_icon} {res['dominant_label']} ({res['sentiment_score']:+.3f})")

        # 계산된 감성 분석 결과를 데이터프레임에 새로운 컬럼으로 추가
        df["sentiment_score"] = scores
        df["sentiment_label"] = labels
        df["prob_positive"] = pos_probs
        df["prob_negative"] = neg_probs
        df["prob_neutral"] = neu_probs

        return df # 감성 분석 결과가 추가된 데이터프레임 반환

# ========== 가중치 계산 함수 정의 ==========
# df: 감성 분석 결과가 포함된 데이터프레임
# half_life_hours: 반감기 (몇 시간 후에 가중치가 절반이 되는지)
def calculate_time_weights(df: pd.DataFrame, half_life_hours=24.0) -> pd.DataFrame:
    df['pub_date'] = pd.to_datetime(df['pub_date']) # 'pub_date' 컬럼을 datetime 형식으로 변환
    df = df.dropna(subset=['pub_date', 'sentiment_score']) # 'pub_date' 또는 'sentiment_score'가 없는 행 제거

    current_time = datetime.now() # 현재 시간
    # 현재 시간과 발행일 간의 시간 차이 (단위: 시간) 계산
    df['time_difference_hours'] = (current_time - df['pub_date']).dt.total_seconds() / 3600.0

    # 반감기를 이용한 감쇠 상수(decay constant) 계산
    decay_constant = np.log(2) / half_life_hours
    # 시간 가중치 계산 (시간이 지날수록 가중치가 감소)
    df['time_weight'] = np.exp(-decay_constant * df['time_difference_hours'])
    # 감성 점수에 시간 가중치를 곱하여 가중 감성 점수 계산
    df['weighted_sentiment_score'] = df['sentiment_score'] * df['time_weight']

    return df # 시간 가중치가 추가된 데이터프레임 반환

# ========== 투자 판단 함수 정의 ==========
# df: 가중 감성 점수가 포함된 데이터프레임
def generate_trading_signal(df: pd.DataFrame) -> dict:
    total_score = df['weighted_sentiment_score'].mean() # 가중 감성 점수의 평균 계산
    # 총 점수를 0-100 스케일로 정규화 (감성 점수 범위가 -1 ~ 1 이므로 +1 후 50을 곱함)
    normalized_score = (total_score + 1) * 50

    # 정규화된 점수에 따라 매매 신호 및 투자 의견 결정
    if normalized_score >= 60:
        signal, opinion = "BUY 🟢", "매수 추천 (긍정적 감성 우세)"
    elif normalized_score <= 40:
        signal, opinion = "SELL 🔴", "매도 추천 (부정적 감성 우세)"
    else:
        signal, opinion = "HOLD 🟡", "관망 (중립적 감성)"

    # 투자 판단 결과 딕셔너리로 반환
    return {
        "signal": signal, # 매매 신호
        "opinion": opinion, # 투자 의견
        "score": round(normalized_score, 2), # 종합 점수
        "positive_count": len(df[df['sentiment_label'] == '긍정']), # 긍정 뉴스 개수
        "negative_count": len(df[df['sentiment_label'] == '부정']), # 부정 뉴스 개수
        "neutral_count": len(df[df['sentiment_label'] == '중립']), # 중립 뉴스 개수
        "total_news": len(df) # 전체 뉴스 개수
    }


print("ngrok 터널 생성 중(8501)...")
try:
    # 8501 포트를 HTTPS 공개 URL로 터널링
    public_url = ngrok.connect(8501, bind_tls=True)
    print("--------------------------------------------------")
    print("접속 URL:")
    print(public_url.public_url)

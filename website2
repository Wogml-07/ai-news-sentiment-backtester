def crawl_naver_news(search_keyword):
    # 네이버 뉴스 검색 Open API를 사용해
    # 특정 키워드(search_keyword) 관련 최신 뉴스 최대 100개를 가져오는 함수
    url = "https://openapi.naver.com/v1/search/news.json"
    params = {
        "query": search_keyword,  # 검색어
        "display": 100,          # 최대 100개 (네이버 뉴스 API display 최대값)
        "sort": "date"           # 최신순 정렬
    }
    headers = {
        "X-Naver-Client-Id": NAVER_CLIENT_ID,
        "X-Naver-Client-Secret": NAVER_CLIENT_SECRET
    }
    try:
        # 타임아웃 5초로 설정하여 너무 오래 기다리지 않음
        resp = requests.get(url, headers=headers, params=params, timeout=5)
        resp.raise_for_status()          # HTTP 에러 발생 시 예외 발생
        data = resp.json()
        return data.get("items", [])     # 뉴스 item 리스트 반환
    except Exception as e:
        print("API 에러:", e)
        return []

def parse_pubdate_to_datetime(pubdate_str):
    # 네이버 뉴스에서 주는 pubDate 문자열을
    # Python datetime 객체로 변환하는 함수
    try:
        # 예: 'Mon, 03 Jun 2026 19:42:00 +0900' 형식
        return datetime.strptime(pubdate_str, "%a, %d %b %Y %H:%M:%S %z")
    except Exception:
        return None

def calc_time_weight(pub_dt, now_dt):
    # 발행 시간(pub_dt)이 현재(now_dt)와 얼마나 떨어져 있는지에 따라
    # 시간 가중치를 계산하는 함수.
    #
    # - pub_dt가 None이면 0.150으로 고정 (정보 없음 → 가치 낮게)
    # - 0시간 차이: 가중치 1.0
    # - 24시간 차이: exp(-24/24) ≈ 0.37
    # - 48시간 차이: exp(-48/24) ≈ 0.14
    # - 너무 작아지지 않도록 하한 0.05 설정
    if pub_dt is None:
        return 0.150

    # 현재(now_dt)와의 시차를 '시간' 단위로 계산
    hours = (now_dt - pub_dt).total_seconds() / 3600.0
    # 이론적으로 미래 시점의 뉴스는 없지만, 만약 음수가 나오면 0으로 보정
    if hours < 0:
        hours = 0.0

    # 지수 감소 함수: 시간이 지날수록 가중치가 지수적으로 줄어듦
    w_raw = math.exp(-hours / 24.0)

    # 0.05 ~ 1.0 사이로 클리핑해서 너무 작거나 크지 않게 제한
    w = max(0.050, min(1.000, w_raw))
    return w


percent_pattern = re.compile(r"([+-]?\\d+(?:\\.\\d+)?)%")

def compute_raw_sentiment_score(text: str) -> float:
    # 뉴스 제목+요약 텍스트에서
    # 키워드/퍼센트/상승·하락 표현을 이용해 원시 감성 점수(raw)를 계산
    t = text.lower()
    raw = 0.0

    # 1) 키워드 기반 점수 부여
    for w in strong_pos:
        if w in t:
            raw += 6.0
    for w in weak_pos:
        if w in t:
            raw += 2.5

    for w in strong_neg:
        if w in t:
            raw -= 6.0
    for w in weak_neg:
        if w in t:
            raw -= 2.5

    # 2) 퍼센트 변동 (+3%, -5% 등)을 점수에 반영
    for match in percent_pattern.findall(t):
        try:
            val = float(match[0])
        except:
            continue
        if val > 0:
            # 상승 퍼센트가 클수록 더 큰 긍정 점수 (상한 8점)
            raw += min(8.0, 0.5 * val)
        elif val < 0:
            # 하락 퍼센트가 클수록 더 큰 부정 점수 (상한 -8점)
            raw -= min(8.0, 0.5 * abs(val))

    # 3) 상승/하락/화살표 패턴에 대한 보정
    if ("↑" in t) or ("상승" in t) or ("급등" in t) or ("강세" in t):
        raw += 4.0
    if ("↓" in t) or ("하락" in t) or ("급락" in t) or ("약세" in t):
        raw -= 4.0

    # 4) 강조어(역대급, 심각한 등)가 있으면 현재 방향을 1.8배 증폭
    if any(amp in t for amp in amplifiers):
        if raw > 0:
            raw *= 1.8
        elif raw < 0:
            raw *= 1.8

    return raw

def scale_sentiment_force_nonzero(text: str, raw: float) -> float:
    # 원시 점수 raw를 [-1, 1] 범위로 스케일링하되,
    # "정확히 0" 값만 피하고, 나머지는 자연스럽게 둔다.
    #  (0이 되면 label을 neutral로 볼 여지가 생기기 때문에 강제로 ± 방향을 부여)
    if raw == 0.0:
        direction = random.choice([-1, 1])
        raw = direction * 1.0  # 아주 작은 비대칭성 부여

    max_abs = 25.0
    # 너무 큰 raw 값은 [-max_abs, max_abs]로 자른다 → 극단값 제한
    clipped = max(-max_abs, min(max_abs, raw))

    # -1.0 ~ +1.0 범위로 단순 선형 스케일링
    scaled = clipped / max_abs

    # float 연산 오차로 딱 0.0이 나오는 경우는 아주 작은 값으로 보정
    if scaled == 0.0:
        scaled = 1e-6  # 0.000001 수준의 양수

    return scaled

def sentiment_label_from_score(scaled: float) -> str:
    # 스케일링된 점수의 부호에 따라 라벨을 결정
    if scaled > 0.0:
        return "positive"
    else:
        return "negative"

def make_investment_decision(total_weighted_score):
    # 뉴스 전체의 가중 감성 점수 합(total_weighted_score)에 따라
    # 최종 투자 의견(매수/매도/관망)을 결정
    if total_weighted_score >= 0.3:
        return "매수", "최근 뉴스 전반이 규칙 기반 감성 분석에서 긍정으로 우세하므로 매수 의견입니다."
    elif total_weighted_score <= -0.3:
        return "매도", "최근 뉴스 전반이 규칙 기반 감성 분석에서 부정으로 우세하므로 매도 의견입니다."
    else:
        return "관망", "긍정/부정이 큰 차이 없이 섞여 있어 관망 의견입니다."

# 🔵 키워드 기반 관련 단어 생성 함수
def make_related_terms(keyword: str):
    \"\"\"예: '삼성전자' → ['삼성전자', '삼성']
        예: 'LG에너지솔루션' → ['lg에너지솔루션', 'lg']

    - 원 키워드 전체(소문자) + 공백으로 나눈 첫 단어(소문자)를 관련 단어 집합으로 사용
    - 이후 제목/요약 텍스트에 이 단어들 중 하나라도 없으면 "관련 없음"으로 보고 필터링
    \"\"\"
    kw = keyword.strip()
    if not kw:
        return []

    # 소문자 기준으로 처리 (대소문자 차이 제거)
    kw_lower = kw.lower()

    # 공백으로 나눠서 첫 단어를 뽑는다 (예: 'LG 에너지솔루션' → 'lg')
    first_token = kw_lower.split()[0]

    # set을 이용해 중복 제거 후 리스트 변환
    terms = {kw_lower, first_token}
    return list(terms)

